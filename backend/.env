# ---------- App meta ----------
app_env=dev
log_level=INFO

# ---------- Database (Postgres in docker-compose) ----------
database_url=postgresql+asyncpg://air:air@db:5432/air
alembic_database_url=postgresql+psycopg://air:air@db:5432/air

# ---------- RAG / Vector store ----------
vector_db_dir=./kb/index
chroma_collection=kb_docs
kb_min_docs=1

# ---------- Policy / approvals (safe defaults) ----------
high_risk_actions_csv=
needs_approval_actions_csv=
nonprod_envs_csv=dev,staging
allow_manual_approval=true

# ---------- Optional adapters ----------
prometheus_url=http://localhost:9090
vite_api_url=/api

# ---------- UI (Vite) ----------
VITE_API_URL=/api

# ---------- Telemetry knobs ----------
ANONYMIZED_TELEMETRY=False
CHROMA_DISABLE_TELEMETRY=1
